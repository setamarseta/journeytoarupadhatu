<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Journey to Arupadhatu - Gacha Destiny Simulation</title>
    <!-- Tailwind CSS untuk Styling Cepat & Estetis -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- Google Fonts: Playfair Display (Serif Elegan) & Montserrat (SANS) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #1A1412; /* Deep Earthy Brown */
        }
        .font-serif {
            font-family: 'Playfair Display', serif;
        }
        /* Efek Animasi Gacha Glowing berkedip */
        @keyframes gachaPulse {
            0%, 100% { border-color: #3A2F2B; box-shadow: none; }
            50% { border-color: #C89D7C; box-shadow: 0 0 15px rgba(200, 157, 124, 0.4); }
        }
        .gacha-active {
            animation: gachaPulse 0.2s infinite ease-in-out;
            background-color: #3A2F2B !important;
        }
    </style>
</head>
<body class="text-[#EAE3D2] min-h-screen flex flex-col items-center justify-between p-4 md:p-8 selection:bg-[#C89D7C] selection:text-[#1A1412]">

    <!-- HEADER -->
    <header class="text-center my-6 max-w-2xl">
        <h1 class="font-serif text-4xl md:text-5xl font-bold tracking-wide text-[#C89D7C] mb-2">Journey to Arupadhatu</h1>
        <p class="text-sm md:text-base text-[#A89886] italic uppercase tracking-widest font-light"></p>
        <div class="h-[1px] w-32 bg-gradient-to-r from-transparent via-[#C89D7C] to-transparent mx-auto mt-4"></div>
    </header>

    <!-- MAIN CONTAINER BOARD -->
    <main class="w-full max-w-4xl bg-[#231B19] border border-[#3A2F2B] rounded-2xl p-6 md:p-10 shadow-2xl backdrop-blur-sm relative space-y-8">
        
        <!-- PUSH GAChA BUTTON & ZONE -->
        <section class="text-center space-y-6 py-4">
            <div class="max-w-md mx-auto space-y-2">
                <h2 class="font-serif text-2xl text-[#EAE3D2]">Anuan Quest</h2>
                <p class="text-xs text-[#A89886] leading-relaxed">apakek .</p>
            </div>

            <div>
                <button onclick="drawGacha()" id="gacha-btn" class="bg-gradient-to-r from-[#C89D7C] to-[#A87C5C] text-[#1A1412] hover:from-[#D7B192] hover:to-[#B98C6B] font-bold text-base px-8 py-4 rounded-xl transition-all shadow-xl transform active:scale-95 flex items-center justify-center gap-3 mx-auto cursor-pointer tracking-wider">
                    ✨ Buka Kitab Takdir 
                </button>
            </div>
        </section>

        
        <section class="space-y-4">
            <h3 class="text-xs text-[#A89886] uppercase tracking-widest text-center">Kemungkinan Aliran Karma (Pool Quest)</h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Card 1 -->
                <div id="qcard-1" class="quest-display-card bg-[#1A1412] border border-[#3A2F2B] p-5 rounded-xl transition-all duration-300 opacity-40">
                    <span class="text-xs text-[#A89886] block font-semibold mb-1">Quest I</span>
                    <span class="font-serif text-lg font-medium block text-[#EAE3D2]">Relief Trade</span>
                </div>
                <!-- Card 2 -->
                <div id="qcard-2" class="quest-display-card bg-[#1A1412] border border-[#3A2F2B] p-5 rounded-xl transition-all duration-300 opacity-40">
                    <span class="text-xs text-[#A89886] block font-semibold mb-1">Quest II</span>
                    <span class="font-serif text-lg font-medium block text-[#EAE3D2]">The Karma Balance</span>
                </div>
                <!-- Card 3 -->
                <div id="qcard-3" class="quest-display-card bg-[#1A1412] border border-[#3A2F2B] p-5 rounded-xl transition-all duration-300 opacity-40">
                    <span class="text-xs text-[#A89886] block font-semibold mb-1">Quest III</span>
                    <span class="font-serif text-lg font-medium block text-[#EAE3D2]">Mirror of Deeds</span>
                </div>
                <!-- Card 4 -->
                <div id="qcard-4" class="quest-display-card bg-[#1A1412] border border-[#3A2F2B] p-5 rounded-xl transition-all duration-300 opacity-40">
                    <span class="text-xs text-[#A89886] block font-semibold mb-1">Quest IV</span>
                    <span class="font-serif text-lg font-medium block text-[#EAE3D2]">Sangha Offering</span>
                </div>
            </div>
        </section>

        <!-- FINAL DISPLAY: HASIL GACHA YANG AKAN TERBUKA -->
        <section id="final-card-panel" class="hidden bg-[#1D1614] border-2 border-[#C89D7C]/30 rounded-xl p-6 md:p-8 space-y-6 relative transition-all duration-300 animate-fade-in">
            <div class="absolute top-0 right-0 transform translate-x-1 -translate-y-2 bg-[#C89D7C] text-[#1A1412] text-xs font-bold px-3 py-1 rounded shadow-md uppercase tracking-wider animate-pulse" id="final-tag">
                HASIL GACHA MURNI
            </div>
            
            <div>
                <h3 id="final-title" class="font-serif text-2xl text-[#C89D7C]">Nama Aksi</h3>
                <div class="h-[1px] w-20 bg-[#C89D7C]/50 mt-1"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-sm">
                <div class="space-y-4">
                    <div>
                        <h5 class="text-xs text-[#A89886] uppercase tracking-wider font-semibold mb-1">📜 Deskripsi Takdir</h5>
                        <p id="final-desc" class="text-[#EAE3D2] leading-relaxed"></p>
                    </div>
                    <div class="bg-[#281F1D] p-4 rounded-lg border border-[#3A2F2B]">
                        <h5 class="text-xs text-[#C89D7C] uppercase tracking-wider font-semibold mb-1">🧘‍♂️ pesan dari </h5>
                        <p id="final-npc" class="text-[#EAE3D2] italic"></p>
                    </div>
                </div>

                <div class="space-y-4 flex flex-col justify-between">
                    <div class="bg-[#231B19] p-4 rounded-lg border-l-4 border-[#C89D7C]">
                        <h5 class="text-xs text-[#A89886] uppercase tracking-wider font-semibold mb-1">⚡aturan </h5>
                        <p id="final-tldr" class="text-[#EAE3D2] font-medium"></p>
                    </div>
                    <div class="bg-[#1F2621] p-4 rounded-lg border border-[#384D3F] flex items-center justify-between">
                        <div>
                            <h5 class="text-xs text-[#8FBC94] uppercase tracking-wider font-semibold mb-0.5">🎁 Konsekuensi / Reward</h5>
                            <p id="final-reward" class="text-[#8FBC94] font-medium text-base"></p>
                        </div>
                        <span class="text-2xl">✨</span>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <!-- FOOTER -->
    <footer class="text-center text-xs text-[#6E5D57] my-6">
        © 2026 Journey to Arupadhatu. Sistem Acak Jagat Raya Tanpa Ego Terikat.
    </footer>

    <!-- JAVASCRIPT LOGIC GACHA ROULETTE -->
    <script>
        // Database Data Quest Sesuai Dokumen Alur
        const mainQuests = {
            1: {
                title: "Relief Trade",
                desc: "Melepaskan keterikatan kepemilikan demi keharmonisan semesta. Lakukan kompromi untuk kemajuan spiritual bersama.",
                npc: "\"Bukalah komunikasi yang jujur. Tukarkan Relief Card milikmu dengan pemain lain melalui jalur negosiasi terbuka.\"",
                tldr: "Tukar Relief Card dengan pemain lain secara negosiasi terbuka.",
                reward: "+3 Langkah untuk KEDUA pemain yang bertransaksi"
            },
            2: {
                title: "The Karma Balance",
                desc: "Waktunya menghitung berat ringannya timbunan niat (Karma) yang terkumpul dalam genggaman tanganmu.",
                npc: "\"Mari kita hitung tumpukanmu. Apakah hasrat duniamu (Strategy) melebihi kebajikan batinmu (Relief)? Hukum karma mutlak.\"",
                tldr: "Audit Kartu Tangan: Jika Strategy Card > Relief Card -> Freeze 1 Ronde. Jika Relief Card >= Strategy Card -> Double Turn.",
                reward: "Double Turn ATAU Freeze (Tergantung Isi Tangan)"
            },
            3: {
                title: "Mirror of Deeds",
                desc: "Langkah hidupmu adalah gaung dari keputusan makhluk lain di sekitarmu. Tidak ada entitas yang benar-benar terisolasi.",
                npc: "\"Pilihlah salah satu cermin jiwa lawanmu. Rasakan resonansi energi kosmis mereka dan biarkan dirimu ikut bergerak maju.\"",
                tldr: "Pilih 1 pemain lawan, pion milikmu ikut bergerak maju sejauh angka dadu terakhir yang mereka lemparkan.",
                reward: "+1 Relief Card Baru"
            },
            4: {
                title: "Sangha Offering",
                desc: "Komunitas pencari kesadaran (Sangha) tidak akan membiarkan ada satu jiwa pun yang tertinggal jauh di belenggu samsara bawah.",
                npc: "\"Salurkan bantuan tulusmu ke kolam pool suci. Sokonglah saudara kita yang berada di barisan paling belakang papan.\"",
                tldr: "Semua pemain menyumbang kartu ke pool kolektif untuk diserahkan ke pemain di urutan paling belakang.",
                reward: "Penyumbang: +2 Langkah | Pemicu Quest: +5 Langkah"
            }
        };

        function drawGacha() {
            const gachaBtn = document.getElementById('gacha-btn');
            const finalPanel = document.getElementById('final-card-panel');
            
            // Mengunci tombol dan menyembunyikan hasil lama saat proses gacha dimulai
            gachaBtn.disabled = true;
            gachaBtn.innerText = "🌀...";
            finalPanel.classList.add('hidden');
            
            let cycleCount = 0;
            let currentHighlight = 1;
            
            // Simulasi Efek Gacha Roulette Berputar Cepat
            const rouletteInterval = setInterval(() => {
                resetCardOpacity();
                
                // Beri highlight acak/bergantian pada pool kartu
                currentHighlight = (currentHighlight % 4) + 1;
                const activeCard = document.getElementById(`qcard-${currentHighlight}`);
                activeCard.classList.remove('opacity-40');
                activeCard.classList.add('gacha-active', 'opacity-100');
                
                cycleCount++;
                
                // Kondisi Berhenti Setelah Putaran Cukup
                if (cycleCount > 15) {
                    clearInterval(rouletteInterval);
                    
                    // Menentukan Hasil Takdir Akhir secara Acak (1-4)
                    const finalQuestResult = Math.floor(Math.random() * 4) + 1;
                    
                    resetCardOpacity();
                    
                    // Kunci Visual Kartu Terpilih
                    const finalCard = document.getElementById(`qcard-${finalQuestResult}`);
                    finalCard.classList.remove('opacity-40');
                    finalCard.classList.add('opacity-100', 'border-[#C89D7C]', 'bg-[#2D2320]');
                    
                    // Render Data ke Panel Bawah
                    renderFinalPanel(mainQuests[finalQuestResult], finalQuestResult);
                    
                    // Kembalikan Keadaan Tombol
                    gachaBtn.disabled = false;
                    gachaBtn.innerText = "✨ Buka Kitab Takdir (GACHA)";
                }
            }, 100);
        }

        function renderFinalPanel(data, idNum) {
            document.getElementById('final-title').innerText = data.title;
            document.getElementById('final-desc').innerText = data.desc;
            document.getElementById('final-npc').innerText = data.npc;
            document.getElementById('final-tldr').innerText = data.tldr;
            document.getElementById('final-reward').innerText = data.reward;
            
            document.getElementById('final-tag').innerText = `TAKDIR QUEST 0${idNum}`;

            // Tampilkan Panel dengan Smooth Scroll
            const finalPanel = document.getElementById('final-card-panel');
            finalPanel.classList.remove('hidden');
            finalPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function resetCardOpacity() {
            document.querySelectorAll('.quest-display-card').forEach(card => {
                card.className = "quest-display-card bg-[#1A1412] border border-[#3A2F2B] p-5 rounded-xl transition-all duration-300 opacity-40";
            });
        }
    </script>
</body>
</html>
